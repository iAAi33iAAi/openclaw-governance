# OpenClaw Governance Platform  Environment Configuration

# API Gateway
API_PORT=8000
API_HOST=0.0.0.0
JWT_SECRET=your-jwt-secret-here

# Colony Agents
AGENT_ORCHESTRATOR_PORT=8001
LOVE_QUALITY_THRESHOLD=0.85
SOVEREIGNTY_VALIDATION=true

# Aethel Grid
AETHEL_GRID_HOST=aethel-grid
AETHEL_GRID_PORT=9000
AETHEL_SAFETY_MODE=strict

# Consensus Engine
CONSENSUS_DIMENSIONS=12
QUORUM_THRESHOLD=0.67

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=openclaw
POSTGRES_USER=openclawPOSTGRES_PASSWORD=change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000